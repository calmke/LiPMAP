ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda-12.1/bin/nvcc

cflags = -pthread -B /home/kezeran/anaconda3/envs/lipmap2/compiler_compat -Wno-unused-result -Wsign-compare -DNDEBUG -fwrapv -O2 -Wall -fPIC -O2 -isystem /home/kezeran/anaconda3/envs/lipmap2/include -fPIC -O2 -isystem /home/kezeran/anaconda3/envs/lipmap2/include -fPIC -I/home/kezeran/anaconda3/envs/lipmap2/lib/python3.10/site-packages/torch/include -I/home/kezeran/anaconda3/envs/lipmap2/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -I/home/kezeran/anaconda3/envs/lipmap2/lib/python3.10/site-packages/torch/include/TH -I/home/kezeran/anaconda3/envs/lipmap2/lib/python3.10/site-packages/torch/include/THC -I/usr/local/cuda-12.1/include -I/home/kezeran/anaconda3/envs/lipmap2/include/python3.10 -c
post_cflags = -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=_C -D_GLIBCXX_USE_CXX11_ABI=0 -std=c++17
cuda_cflags = -I/home/kezeran/anaconda3/envs/lipmap2/lib/python3.10/site-packages/torch/include -I/home/kezeran/anaconda3/envs/lipmap2/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -I/home/kezeran/anaconda3/envs/lipmap2/lib/python3.10/site-packages/torch/include/TH -I/home/kezeran/anaconda3/envs/lipmap2/lib/python3.10/site-packages/torch/include/THC -I/usr/local/cuda-12.1/include -I/home/kezeran/anaconda3/envs/lipmap2/include/python3.10 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -I/home/kezeran/code/LiPMAP/submodules/quaternion-utils/third_party/glm/ -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=_C -D_GLIBCXX_USE_CXX11_ABI=0 -gencode=arch=compute_86,code=compute_86 -gencode=arch=compute_86,code=sm_86 -std=c++17
cuda_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags





build /home/kezeran/code/LiPMAP/submodules/quaternion-utils/build/temp.linux-x86_64-cpython-310/ext.o: compile /home/kezeran/code/LiPMAP/submodules/quaternion-utils/ext.cpp
build /home/kezeran/code/LiPMAP/submodules/quaternion-utils/build/temp.linux-x86_64-cpython-310/quat.o: cuda_compile /home/kezeran/code/LiPMAP/submodules/quaternion-utils/quat.cu
build /home/kezeran/code/LiPMAP/submodules/quaternion-utils/build/temp.linux-x86_64-cpython-310/quat_convert.o: cuda_compile /home/kezeran/code/LiPMAP/submodules/quaternion-utils/quat_convert.cu






